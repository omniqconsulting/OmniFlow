# OmniFlow — Environment Variables Template
# Copy this file to .env and fill in real values. Never commit .env itself.

ANTHROPIC_API_KEY=sk-ant-api03-...your-key-here...

# --- Core (fails fast on Render if unset — see app/database.py, app/auth.py) ---
DATABASE_URL=postgresql://user:password@host:5432/dbname
SECRET_KEY=generate-a-long-random-value-do-not-reuse-the-dev-default

# --- Web Push (VAPID) — fails fast on Render if unset, see app/push.py ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@yourdomain.com

# --- CORS (Phase 0.5 — comma-separated list of allowed origins for the API) ---
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# --- API docs (Phase 0.5 security audit — /docs, /redoc, /openapi.json) ---
# Leave unset in production to keep them internal-only. Set to "true" to expose them.
ENABLE_API_DOCS=false

# --- Cloudflare R2 (object storage for uploads — app/storage.py) ---
# Leave unset to fall back to local disk (fine for local dev; do NOT rely on
# this in production, Render's filesystem is ephemeral and wipes uploads on
# every deploy/restart). Public bucket serves catalog/training media via
# R2_PUBLIC_BASE_URL; private bucket serves employee documents via signed URLs.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=
R2_BUCKET_PRIVATE=
R2_PUBLIC_BASE_URL=https://files.yourdomain.com

# --- Optional / feature-specific ---
OMNIFLOW_PUBLIC_DOMAIN=
PLATFORM_ALERT_TENANT_ID=
SA_ALERT_PHONE=
SALES_MARGIN_FLOOR_PCT=
BULK_IMPORT_MAX_ROWS=

# Set automatically by Render — do not set manually in local .env
# RENDER=true

# Per-tenant Gupshup (client_id, secret_token, source_number, webhook_token,
# webhook_secret) and Razorpay keys are stored in the database per tenant,
# not as environment variables — see app/services/gupshup.py.
